{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Python static server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "3000"],
      "port": 3000
    },
    {
      "name": "npx serve",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "-p", "3001", "--no-clipboard"],
      "port": 3001
    },
    {
      "name": "npx http-server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", ".", "-p", "3002", "--cors", "-c-1"],
      "port": 3002
    }
  ]
}
